# ═══ Oak Configuration ═══

# Ollama host (default: http://localhost:11434)
# OLLAMA_HOST=http://localhost:11434

# Override the auto-detected model (optional)
# OAK_MODEL=qwen2.5-coder:7b

# GitHub personal access token (for private repos)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server host/port
# CODEPILOT_HOST=127.0.0.1
# CODEPILOT_PORT=8800

# Code execution timeout in seconds
# CODE_EXEC_TIMEOUT=30

# Disable code execution entirely
# CODE_EXEC_ENABLED=true

# Joplin integration (get token from Joplin → Settings → Web Clipper)
# JOPLIN_TOKEN=your_joplin_api_token_here
# JOPLIN_URL=http://localhost:41184
